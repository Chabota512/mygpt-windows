{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My_GPT 4 Students",
  "version": "0.1.0",
  "identifier": "app.mygpt.students",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../artifacts/student-ai/dist/public"
  },
  "app": {
    "windows": [
      {
        "title": "My_GPT 4 Students",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "My_GPT 4 Students"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mygpt-backend"],
    "resources": [],
    "category": "Productivity",
    "shortDescription": "Offline AI study assistant",
    "longDescription": "My_GPT 4 Students runs three small local LLMs through Ollama for vision, reasoning, and writing — fully offline.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English"]
      }
    }
  },
  "plugins": {}
}
